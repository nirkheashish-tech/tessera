{
  "name": "tessera",
  "version": "1.0.0",
  "description": "A powerful, open-source multi-pane web app wrapper. Run multiple instances of any web app side-by-side in one window with full customization.",
  "main": "src/main/main.js",
  "author": {
    "name": "Tessera Contributors",
    "email": "tessera@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/AshishSardana/tessera",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishSardana/tessera.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --win --linux",
    "dist:mac": "electron-builder --mac --arm64 --x64",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.tessera.app",
    "productName": "Tessera",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.png"
    }
  }
}
